# Bridgy — copy or merge this into .env.local and fill in the values.
# .env.local is gitignored. Never paste these values into chat or commit them.

# ===== Projects =====
# Absolute path to the folder whose subfolders are your projects.
# The bridge will refuse to operate on anything outside this root.
# Don't point this at OneDrive / Dropbox / iCloud — the bridge stores
# a passkey credentials file under this folder and you don't want
# that synced to a cloud provider.
PROJECTS_ROOT=C:\path\to\your\projects

# ===== Web UI =====
# Mobile-first PWA the bridge serves for the iPhone. Recommended access:
# Tailscale on phone + laptop, then open https://<laptop-tailscale-name>:8787
# from the phone and tap "Add to Home Screen". WEB_PASSWORD is the only
# auth between the phone and the bridge — pick something strong. Brute-
# force defense: 5 failed attempts per IP per minute then 429, plus a
# 500ms delay on each failure.

# Listen address. 0.0.0.0 is fine on Tailscale (the Tailscale ACL gates
# who can reach 0.0.0.0:WEB_PORT). Use 127.0.0.1 for local-only testing
# or if you're not running Tailscale.
WEB_HOST=0.0.0.0
WEB_PORT=8787

# Required. Passphrase you type once on the phone — MINIMUM 10 chars.
# Examples: "correct-horse-battery", "lake-river-mountain-7". Single short
# words are rejected. The PWA's "Save Password" prompt in iOS Safari
# autofills it after the first login.
WEB_PASSWORD=

# When `true` (the default), the workspace picker (Menu -> Workspace)
# can only browse folders inside PROJECTS_ROOT. Set to `false` to allow
# the picker to jump to Home / Desktop / Documents / any absolute path
# on the laptop — this widens the attack surface of an authenticated
# session, so leave it true unless you understand the trade-off.
WORKSPACE_ROOT_LOCK=true

# Set to 1 (or "true") ONLY if you're putting an HTTPS terminator in front
# of the bridge (cloudflared, caddy, nginx) OR using a Tailscale cert.
# Leave false for plain http on Tailscale.
CRC_COOKIE_SECURE=false

# Optional. Full HTTPS URL the bridge is reachable at (e.g. a Tailscale
# Serve URL). If set, the static HTML pages auto-redirect HTTP visitors
# to this URL — needed because the phone's mic + Face ID require HTTPS.
CRC_HTTPS_URL=

# Per-request upload cap for /api/upload, in megabytes.
WEB_MAX_UPLOAD_MB=50

# Per-frame WebSocket size cap, in kilobytes. Bounds a single `prompt` text.
WEB_MAX_WS_FRAME_KB=256

# Maximum number of simultaneous `claude -p` subprocesses across all
# projects. Cap so a rapid-fire client can't fork-bomb the laptop.
MAX_CONCURRENT_RUNS=6

# ===== Claude Code =====
# Path to the claude CLI executable. On Windows this is usually "claude.cmd"
# on PATH, or the full path under %APPDATA%\npm\claude.cmd. Run `where claude`
# in PowerShell to find it.
CLAUDE_CMD=claude

# Default permission mode at startup. Options: auto | plan | edits
# - auto  → --dangerously-skip-permissions  (full auto, no prompts)
# - plan  → --permission-mode plan          (read-only planning)
# - edits → --permission-mode acceptEdits   (auto-accept edits, stall on bash)
#
# ⚠️ SECURITY: `auto` = ARBITRARY CODE EXECUTION for anyone who can log
# in to the bridge. The bridge is designed for single-user, trusted-
# network setups (Tailscale + a strong password). If you have ANY
# reason to think someone else might authenticate (shared password,
# laptop loaned out, internet-exposed instance, etc.), change this to
# `plan` or `edits` — both prevent unattended shell execution.
CLAUDE_DEFAULT_PERMISSION_MODE=auto

# ⚠️ Secrets you add to this file (API keys, OAuth tokens, etc.) are
# passed through into every `claude -p` subprocess's environment by
# default. Claude can read them with its Bash tool (`printenv FOO`).
# Only `WEB_PASSWORD` and a couple of legacy keys are auto-scrubbed.
# To hide additional names, list them in BRIDGE_SCRUB_ENV (comma-
# separated). Example:
#   BRIDGE_SCRUB_ENV=PERPLEXITY_API_KEY,STRIPE_SECRET,DATABASE_URL
BRIDGE_SCRUB_ENV=

# Optional: pin the model used by claude -p when the mobile picker is on
# "Auto". Leave blank to use claude.exe's own default (typically Sonnet
# for Pro / Max plans). Examples: claude-sonnet-4-6, claude-opus-4-7,
# claude-haiku-4-5-20251001.
CLAUDE_MODEL=

# Optional: override the auto-detected LAN IP the bridge tells Claude when
# starting dev servers on your behalf. Auto-detection works for most home
# networks; set this if your machine has multiple interfaces and Claude
# keeps reporting the wrong one. Leave blank to auto-detect.
LAN_IP=

# ===== Mic / Whisper =====
# The mic button in the composer records audio on the phone, POSTs it
# to /api/transcribe, and runs faster-whisper locally on the laptop —
# audio bytes are never written to disk. On first use the model auto-
# downloads to ~/.cache/huggingface; subsequent runs load from cache.
#
# WHISPER_MODEL options (size, RAM, English-only):
#   tiny.en   ~75 MB,  fastest, decent
#   base.en   ~140 MB, fast,   good        (default)
#   small.en  ~460 MB, slower, much better
#   medium.en ~1.5 GB, GPU recommended
# Use the multilingual variants (no `.en`) for non-English speech.
WHISPER_MODEL=base.en
# WHISPER_DEVICE: cpu | cuda. cpu is fine for base.en; cuda needs a
# CUDA-enabled ctranslate2 build on Windows.
WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE: int8 on CPU is the right speed/quality trade-off.
# Other valid values: int8_float16, float16, float32.
WHISPER_COMPUTE_TYPE=int8
# Optional: force a language hint instead of model auto-detect. Leave
# blank for English (.en) models; set to e.g. "es" / "fr" for multilingual.
WHISPER_LANG=

# ===== Watcher =====
# Folder names (relative to a project) to watch for new media files. When
# claude (or any other process) writes an image or video into one of these
# folders during an active run, the bridge auto-attaches it to the chat.
WATCH_FOLDERS=assets,output,screenshots

# Max media file size to auto-forward, in megabytes.
MAX_MEDIA_MB=20

# ===== Web Push =====
# VAPID `sub` claim used in the JWT sent to Apple's push gateway (APNs)
# and FCM. RFC 8292 says this should be a contact URI for abuse reports;
# the gateway sees it but it is never forwarded to the phone, never
# logged, and never appears in WebSocket frames. The default below is
# the RFC 2606 reserved domain — safe to ship as-is. If you want a
# real contact on file with Apple in case of push delivery issues,
# replace with your own email.
WEB_PUSH_EMAIL=mailto:webpush@example.com

# ===== Logging =====
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
